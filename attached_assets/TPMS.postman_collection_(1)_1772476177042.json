  "item": [
    {
      "name": "Auth",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Parse XML safely and extract ns2:token value, accounting for namespaces\r",
              "// Do not use JSON parsing per requirement.\r",
              "\r",
              "pm.test(\"Parse XML and set collection token\", function () {\r",
              "    // Get raw XML as text\r",
              "    const xml = pm.response.text();\r",
              "\r",
              "    // Use DOMParser via Postman sandbox to parse XML\r",
              "    // Fallback to regex if DOMParser is unavailable (older sandboxes)\r",
              "    let token = null;\r",
              "\r",
              "    try {\r",
              "        // xml2Json is available in Postman tests; it preserves namespaced keys using ':' in property names\r",
              "        var jsonObject = xml2Json(xml);\r",
              "        // Find the token regardless of default namespace prefix by checking typical structures\r",
              "        // The root is likely ns2:TokenResponse with default namespace aliases\r",
              "        // xml2Json keeps namespace prefixes in the key names. We'll search recursively for a key ending with ':token'.\r",
              "        function findToken(obj) {\r",
              "            if (!obj || typeof obj !== 'object') return null;\r",
              "            // Direct hit\r",
              "            if (Object.prototype.hasOwnProperty.call(obj, 'ns2:token')) {\r",
              "                // xml2Json wraps text nodes as string values\r",
              "                return obj['ns2:token'];\r",
              "            }\r",
              "            // Some XMLs may drop prefix during conversion, try plain 'token'\r",
              "            if (Object.prototype.hasOwnProperty.call(obj, 'token')) {\r",
              "                return obj['token'];\r",
              "            }\r",
              "            // Recurse\r",
              "            for (const k of Object.keys(obj)) {\r",
              "                const v = obj[k];\r",
              "                const found = findToken(v);\r",
              "                if (found) return found;\r",
              "            }\r",
              "            return null;\r",
              "        }\r",
              "\r",
              "        token = findToken(jsonObject);\r",
              "    } catch (e) {\r",
              "        // As a last resort, use a conservative regex to capture <ns2:token>...</ns2:token>\r",
              "        const m = xml.match(/<ns2:token>([\\s\\S]*?)<\\/ns2:token>/i);\r",
              "        if (m) token = m[1].trim();\r",
              "    }\r",
              "\r",
              "    pm.expect(token, 'ns2:token should be present in XML').to.be.a('string').and.not.empty;\r",
              "\r",
              "    // Save to collection variable\r",
              "    pm.collectionVariables.set('token', token);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
