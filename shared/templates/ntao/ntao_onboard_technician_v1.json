{
  "id": "ntao_onboard_technician_v1",
  "name": "NTAO Technician Onboarding",
  "department": "NTAO",
  "workflowType": "onboarding",
  "version": "1.0",
  "description": "Onboarding process for NTAO technician",
  "requiredRole": "agent",
  "steps": [
    {
      "id": "systems_verification",
      "title": "Design ideal truck stock",
      "description": "verify the correct truck assortment is applied to this truck",
      "required": true,
      "category": "verification"
    },
    {
      "id": "release_verification", 
      "title": "Verify if the tech signed the release to ship parts to their home",
      "description": "Confirm signed authorization for parts shipment to technician's home address",
      "required": true,
      "category": "verification",
      "conditionalLogic": {
        "dependsOn": "tech_fssl_status",
        "condition": "not_equals",
        "value": "fssl_flagged"
      }
    },
    {
      "id": "parts_verification",
      "title": "Verify parts to ship",
      "description": "Review and confirm the complete parts list for the new technician",
      "required": true,
      "category": "verification"
    },
    {
      "id": "parts_shipment",
      "title": "Ship part stock to new hire",
      "description": "Process and ship approved parts inventory to technician's address",
      "required": true,
      "category": "system_action"
    }
  ],
  "finalDisposition": {
    "required": true,
    "options": [
      {
        "value": "onboarded",
        "label": "Technician Successfully Onboarded to NTAO",
        "requiresApproval": false
      },
      {
        "value": "pending_advanced_training",
        "label": "Pending Advanced Training Completion",
        "requiresApproval": false
      },
      {
        "value": "requires_additional_certification",
        "label": "Requires Additional Technical Certification",
        "requiresApproval": true
      }
    ]
  },
  "metadata": {
    "createdAt": "2025-01-11T23:20:00Z",
    "createdBy": "system",
    "tags": ["onboarding", "technician", "ntao", "network", "optimization"],
    "isActive": true
  }
}